# API Dash — Provider Keys
# Copy to .env and fill in the ones you use.
# Only providers with keys will appear on the dashboard.

# Anthropic (Claude) — needs admin key for billing API
ANTHROPIC_ADMIN_KEY=

# OpenAI — needs admin key for cost API
OPENAI_ADMIN_KEY=

# fal.ai
FAL_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Venice
VENICE_API_KEY=

# Replicate
REPLICATE_API_TOKEN=

# Azure TTS
AZURE_SPEECH_KEY=

# Optional: budget limit (USD/month) — gauge turns red when exceeded
MONTHLY_BUDGET=100

# Optional: port (default 3737)
PORT=3737
